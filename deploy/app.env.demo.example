HOST_BIND_ADDRESS=127.0.0.1
HOST_PORT=3000

AUTH_MODE=native-oidc
REQUIRE_AUTH=true
TRUST_PROXY_AUTH=false
AUTH_LOGOUT_URL=

OIDC_ISSUER_URL=https://idp.example.net/realms/betreuungskalender-demo
OIDC_CLIENT_ID=betreuungskalender
OIDC_CLIENT_SECRET=CHANGE_ME
OIDC_REDIRECT_URI=https://bk-demo.saas-lab.de/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URI=https://bk-demo.saas-lab.de/
OIDC_SCOPES=openid email profile
OIDC_GROUPS_CLAIM=groups
OIDC_ADMIN_GROUP=/betreuungskalender/admins
OIDC_PARENT_GROUP=/betreuungskalender/parents
OIDC_READONLY_GROUP=/betreuungskalender/readers
OIDC_REQUIRE_ROLE_CLAIM=true

SESSION_COOKIE_NAME=betreuungskalender_demo_session
SESSION_TTL_SECONDS=2419200
ALLOWED_ORIGIN=https://bk-demo.saas-lab.de
LOG_LEVEL=info
RATE_LIMIT_MAX=120
RATE_LIMIT_WRITE_MAX=20
RATE_LIMIT_SENSITIVE_MAX=5
RATE_LIMIT_EXPORT_MAX=15
RATE_LIMIT_WINDOW_MS=60000
DEMO_DATASETS_ENABLED=true
BACKUP_RETENTION_DAYS=14

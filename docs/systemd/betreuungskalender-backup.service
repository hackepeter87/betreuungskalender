[Unit]
Description=Create Betreuungskalender SQLite backup
After=betreuungskalender.service

[Service]
Type=oneshot
User=betreuung
Group=betreuung
WorkingDirectory=/opt/betreuungskalender
EnvironmentFile=/etc/betreuungskalender/.env
ExecStart=/usr/bin/npm run backup
UMask=0077
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/var/lib/betreuungskalender /var/backups/betreuungskalender

NODE_ENV=production
PORT=3000
HOST=0.0.0.0
DATABASE_PATH=/var/lib/betreuungskalender/app.sqlite
BACKUP_DIR=/var/backups/betreuungskalender
REQUIRE_AUTH=true
TRUST_PROXY_AUTH=true
ALLOWED_ORIGIN=https://betreuung.example.net
LOG_LEVEL=info
RATE_LIMIT_MAX=120
RATE_LIMIT_WRITE_MAX=20
RATE_LIMIT_SENSITIVE_MAX=5
RATE_LIMIT_EXPORT_MAX=15
RATE_LIMIT_WINDOW_MS=60000
BACKUP_RETENTION_DAYS=14

NODE_ENV=production
APP_RELEASE_VERSION=1.3.0
APP_RELEASE_DIR=/opt/svc_betreuung/betreuungskalender/releases/v1.3.0
HOST_BIND_ADDRESS=127.0.0.1
HOST_PORT=3000
AUTH_MODE=local
REQUIRE_AUTH=true
TRUST_PROXY_AUTH=false
AUTH_LOGOUT_URL=
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
OIDC_POST_LOGOUT_REDIRECT_URI=
OIDC_SCOPES=openid email profile
OIDC_GROUPS_CLAIM=groups
OIDC_USER_ID_HEADER=x-auth-request-user
OIDC_EMAIL_HEADER=x-auth-request-email
OIDC_DISPLAY_NAME_HEADER=x-auth-request-preferred-username
OIDC_GROUPS_HEADER=x-auth-request-groups
OIDC_ADMIN_GROUP=/betreuungskalender/admins
OIDC_PARENT_GROUP=/betreuungskalender/parents
OIDC_READONLY_GROUP=/betreuungskalender/readers
OIDC_REQUIRE_ROLE_CLAIM=false
SESSION_COOKIE_NAME=betreuungskalender_session
SESSION_TTL_SECONDS=2419200
ALLOWED_ORIGIN=https://betreuung.example.net
LOG_LEVEL=info
RATE_LIMIT_MAX=120
RATE_LIMIT_WRITE_MAX=20
RATE_LIMIT_SENSITIVE_MAX=5
RATE_LIMIT_EXPORT_MAX=15
RATE_LIMIT_WINDOW_MS=60000
DEMO_DATASETS_ENABLED=false
BACKUP_RETENTION_DAYS=14

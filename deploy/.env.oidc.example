NODE_ENV=production
APP_RELEASE_VERSION=1.0.0
APP_RELEASE_DIR=/opt/svc_betreuung/betreuungskalender/releases/v1.0.0
APP_COMPOSE_FILE=compose.oidc.yml
OAUTH2_PROXY_IMAGE=quay.io/oauth2-proxy/oauth2-proxy:v7.15.3
HOST_BIND_ADDRESS=0.0.0.0
HOST_PORT=8080
REQUIRE_AUTH=true
TRUST_PROXY_AUTH=true
ALLOWED_ORIGIN=https://app.example.net
LOG_LEVEL=info
RATE_LIMIT_MAX=120
RATE_LIMIT_WRITE_MAX=20
RATE_LIMIT_SENSITIVE_MAX=5
RATE_LIMIT_EXPORT_MAX=15
RATE_LIMIT_WINDOW_MS=60000
BACKUP_RETENTION_DAYS=14

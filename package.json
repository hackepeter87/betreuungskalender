{
  "name": "betreuungskalender",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n frontend,backend -c cyan,green \"npm:dev:frontend\" \"npm:dev:server\"",
    "dev:frontend": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -p tsconfig.server.json && node scripts/copy-migrations.js && tsc -b && vite build",
    "start": "node dist-server/server/index.js",
    "backup": "node scripts/backup.js",
    "restore:check": "node scripts/restore-check.js",
    "healthcheck": "node scripts/healthcheck.js",
    "lint": "npm run typecheck",
    "test": "tsx --test server/auth.test.ts server/backupRestore.test.ts server/externalCalendars.test.ts server/legacyMigration.test.ts scripts/i18n.test.ts scripts/legacy-local-storage.test.ts scripts/pwa-service-worker.test.js scripts/release-check.test.js",
    "test:e2e": "playwright test",
    "test:security-runtime": "tsx --test scripts/runtime-security.test.ts",
    "test:container-smoke": "bash scripts/container-smoke.sh",
    "release:check": "node scripts/release-check.js",
    "release:check:strict": "node scripts/release-check.js --strict --all --tag",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.server.json --noEmit --pretty false && tsc -b --pretty false"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "better-sqlite3": "^12.4.1",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "ical.js": "^2.2.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^10.0.3",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
